# Calendar backend: 'ical' or 'google'
CALENDAR_BACKEND=ical

# --- iCal backend ---
# Paste your secret iCal URL(s) from Google Calendar → Settings → each calendar →
# "Secret address in iCal format". Comma-separated for multiple calendars.
ICAL_URLS=https://calendar.google.com/calendar/ical/youraddress/basic.ics

# --- Google API backend (leave blank if using ical) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_IDS=

# Port the app runs on
PORT=3000

# For Google Calendar OAuth, the redirect URI must match:
# http://localhost:<PORT>/api/calendar/callback

# Optional: store tasks, calendar config, tokens, and GUI state outside the app repo.
# By default the app stores local data in ./data.
# This directory can itself be a private git repo so snapshot history tracks only your
# personal planning data, not the software source code.
# GANTT_DATA_DIR=/absolute/path/to/private/gantt_app_data

# Basic planning works without Git. Git is only needed if you want the History panel
# to save snapshots into a git-backed data directory.

# A random string used to sign sessions — generate one at random, doesn't matter what it is
SESSION_SECRET=change-this-to-any-long-random-string
