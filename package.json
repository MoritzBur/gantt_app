{
  "name": "gantt-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": "server/prod.js",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite client/",
    "build": "vite build client/",
    "start": "node server/prod.js",
    "build:windows:exe": "npm run build && pkg . --targets node18-win-x64 --output \"dist/windows/Gantt App.exe\" --public --public-packages \"*\" --compress GZip",
    "build:windows:installer": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/windows/build-installer.ps1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "codemirror": "^6.0.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "googleapis": "^144.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "node-ical": "^0.25.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.2.1",
    "pkg": "^5.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.6",
    "wx-react-gantt": "^1.3.1"
  },
  "pkg": {
    "scripts": [
      "server/**/*.js"
    ],
    "assets": [
      "client/dist/**/*",
      "server/workspace-templates/**/*"
    ]
  }
}
